# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/
*.egg

# Paperclip (cloned framework - users clone separately)
paperclip/

# Model weights and large files
workspace/models/**/*.safetensors
workspace/models/**/*.bin
workspace/models/**/*.pt
workspace/models/**/*.gguf
datasets/**/*.jsonl
datasets/**/*.csv
datasets/**/*.parquet
datasets/**/*.json
!datasets/.gitkeep

# HuggingFace cache
.cache/

# Workspace runtime data (generated by agents)
workspace/datasets/**/*.jsonl
workspace/datasets/**/*.json
!workspace/datasets/.gitkeep
workspace/eval_results/**/*.json
workspace/eval_results/**/*.jsonl
!workspace/eval_results/.gitkeep
workspace/infra/active_gpu.yaml
workspace/infra/active_inference.yaml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code
.claude/

# Env files with secrets
.env
*.env.local
